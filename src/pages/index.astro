---
// ============================================================
// index.astro — Pagina principal de salixweb.com
// Aca se ensamblan todos los componentes.
// ============================================================
import Plantilla           from '../layouts/Plantilla.astro';
import Nav                 from '../components/Nav.astro';
import Hero                from '../components/Hero.astro';
import CarruselTecnologias from '../components/CarruselTecnologias.astro';
import SeccionProductos    from '../components/SeccionProductos.astro';
import SeccionFeatures     from '../components/SeccionFeatures.astro';
import SeccionPlanes       from '../components/SeccionPlanes.astro';
import BannerCTA           from '../components/BannerCTA.astro';
import SeccionTestimonios  from '../components/SeccionTestimonios.astro';
import Footer              from '../components/Footer.astro';
---

<Plantilla
  titulo="Salix — Software que simplifica tu negocio"
  descripcion="Suite de apps PWA para gestionar servicios, delivery, canchas y turnos. Pensado para empresas argentinas. WhatsApp + MercadoPago integrados."
>
  <Nav />

  <main>
    <Hero />
    <CarruselTecnologias />
    <SeccionProductos />
    <SeccionFeatures />
    <SeccionPlanes />
    <BannerCTA />
    <SeccionTestimonios />

    <!-- Seccion de contacto -->
    <div class="fondo-puntos" id="contacto">
      <div class="seccion" style="text-align:center;display:flex;flex-direction:column;align-items:center;gap:1.5rem">
        <span class="etiqueta">Contacto</span>
        <h2 class="titulo-seccion">
          <span>Hablemos.</span><br>
          <span style="color:var(--gris-titulo)">Sin compromiso.</span>
        </h2>
        <p class="typewriter subtitulo" style="text-align:center" data-texto="Contanos que necesitas y te decimos como Salix puede ayudarte."></p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:0.5rem">
          <a href="mailto:hola@salixweb.com" class="boton boton-primario">
            Escribirnos
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
          <a href="https://wa.me/5491100000000" class="boton boton-secundario" target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Plantilla>
