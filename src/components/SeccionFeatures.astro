---
// ============================================================
// SeccionFeatures.astro — Grilla "Por que Salix" (6 items)
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';
import GridMagnetico from './ui/GridMagnetico.astro';

interface Feature {
  titulo:      string;
  descripcion: string;
  icono:       string;
}

const FEATURES: Feature[] = [
  { titulo: '100% local',            descripcion: 'Entendemos AFIP, la moneda y como se trabaja aca. Sin configuraciones genericas.',     icono: 'ubicacion' },
  { titulo: 'Rapido de implementar', descripcion: 'Sin meses de configuracion ni consultores caros. Operativo en dias.',                    icono: 'rayo'      },
  { titulo: 'Productos conectados',  descripcion: 'Todos comparten la misma base. Tus datos fluyen entre herramientas sin friccion.',        icono: 'link'      },
  { titulo: 'IA integrada',          descripcion: 'Automatizaciones y analisis inteligente disponibles en toda la suite.',                   icono: 'ia'        },
  { titulo: 'WhatsApp nativo',       descripcion: 'Todas las apps se integran con WhatsApp. Tus clientes y vos, siempre conectados.',       icono: 'whatsapp'  },
  { titulo: 'Pagos con MercadoPago', descripcion: 'Links de pago automaticos. Cobra sin fricciones desde cualquier producto.',               icono: 'pago'      },
];

const TEXTO = {
  etiqueta:  'Por que Salix',
  titulo:    'Pensado para el negocio real.',
  subtitulo: 'No somos una solucion generica importada. Cada detalle esta diseñado para la forma en que se trabaja en Argentina.',
};
---

<GridMagnetico id="grid-features" clase="fondo-puntos">
  <div class="panel-interior">
    <section class="seccion" id="porque">

      <div class="encabezado-seccion aparecer">
        <span class="etiqueta">{TEXTO.etiqueta}</span>
        <h2 class="titulo-seccion">{TEXTO.titulo}</h2>
        <p class="typewriter subtitulo" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>
      </div>

      <div class="grilla-features" role="list">
        {FEATURES.map((feat, indice) => (
          <div class={`item-feature aparecer delay-${indice + 1}`} role="listitem">
            <div class="icono-contenedor feat-icono">
              <IconoSVG nombre={feat.icono} tamaño={22} grosor={1.5} />
            </div>
            <h3 class="feat-titulo">{feat.titulo}</h3>
            <p class="feat-texto">{feat.descripcion}</p>
          </div>
        ))}
      </div>

    </section>
  </div>
</GridMagnetico>

<style>
  .encabezado-seccion {
    margin-bottom: 3rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }

  .grilla-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--borde);
    border-radius: var(--radio-card);
    overflow: hidden;
    border: 1px solid var(--borde);
  }

  .item-feature {
    background: var(--fondo);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex; flex-direction: column; gap: 0.75rem;
    transition: background var(--transicion);
  }

  .item-feature:hover { background: var(--card-hover); }
  .item-feature:hover .feat-icono { transform: scale(1.1) rotate(-5deg); }

  .feat-icono {
    transition: transform 0.4s cubic-bezier(.34,1.56,.64,1);
  }

  .feat-titulo {
    font-size: 1rem; font-weight: 700; color: var(--texto);
    letter-spacing: -.02em; line-height: 1.3;
  }

  .feat-texto {
    font-size: 0.85rem; color: var(--texto-secundario);
    line-height: 1.7;
  }

  @media (max-width: 1024px) { .grilla-features { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grilla-features { grid-template-columns: 1fr; } }
</style>
