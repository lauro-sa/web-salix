---
// ============================================================
// SeccionPlanes.astro — Resumen de precios por producto
// Cada card lleva a la pagina individual del producto
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';

interface PlanProducto {
  nombre:     string;
  desde:      string;
  detalle:    string;
  icono:      string;
  url:        string;
  disponible: boolean;
}

const PRODUCTOS: PlanProducto[] = [
  { nombre: 'Flux',           desde: 'USD $150',   detalle: '/mes · 3 planes',              icono: 'flujo',    url: '/flux',           disponible: true  },
  { nombre: 'Sites',          desde: 'A medida',   detalle: 'segun proyecto',               icono: 'sitio',    url: '/sites',          disponible: true  },
  { nombre: 'Go',             desde: 'USD $100',   detalle: '/mes · 2 planes',              icono: 'delivery', url: '/go',             disponible: false },
  { nombre: 'Play',           desde: 'USD $80',    detalle: '/mes · 2 planes',              icono: 'cancha',   url: '/play',           disponible: false },
  { nombre: 'Book',           desde: 'USD $100',   detalle: '/mes · 2 planes',              icono: 'agenda',   url: '/book',           disponible: false },
  { nombre: 'Integraciones',  desde: 'USD $70',    detalle: 'primera sesion',               icono: 'link',     url: '/integraciones',  disponible: true  },
];

const TEXTO = {
  etiqueta:  'Precios',
  titulo:    'Simple y transparente.',
  subtitulo: 'Cada producto tiene su precio. Sin sorpresas, sin letra chica.',
};
---

<section class="seccion" id="planes">

  <div class="encabezado-seccion aparecer" style="text-align:center;align-items:center">
    <span class="etiqueta">{TEXTO.etiqueta}</span>
    <h2 class="titulo-seccion">{TEXTO.titulo}</h2>
    <p class="typewriter subtitulo" style="text-align:center" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>
  </div>

  <div class="grilla-precios">
    {PRODUCTOS.map((prod, indice) => (
      <a href={prod.url} class={`card-precio aparecer-escala delay-${indice + 1}`}>
        <div class="precio-cabecera">
          <div class="icono-contenedor item-precio">
            <IconoSVG nombre={prod.icono} tamaño={20} grosor={1.5} />
          </div>
          <span class={`etiqueta-estado ${prod.disponible ? 'disponible' : 'proximamente'}`}>
            <span class="punto-estado"></span>
            {prod.disponible ? 'Disponible' : 'Pronto'}
          </span>
        </div>
        <h3 class="precio-nombre">{prod.nombre}</h3>
        <div class="precio-valor">
          <span class="precio-monto">{prod.desde}</span>
          <span class="precio-periodo">{prod.detalle}</span>
        </div>
        <span class="precio-link">
          Ver detalle
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
    ))}
  </div>

</section>

<style>
  .encabezado-seccion {
    margin-bottom: 3rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }

  .grilla-precios {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .card-precio {
    background: var(--card); border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    padding: clamp(1.25rem, 2.5vw, 1.5rem);
    display: flex; flex-direction: column; gap: 0.75rem;
    transition: all var(--transicion);
    text-decoration: none; color: inherit; position: relative;
  }

  .card-precio::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px; background: var(--salix);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-precio:hover {
    border-color: var(--salix-borde); transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.07);
  }

  .card-precio:hover::before { transform: scaleX(1); }
  .card-precio:hover .icono-contenedor { transform: scale(1.1) rotate(-5deg); }
  .card-precio:hover .precio-link { color: var(--salix); }

  .precio-cabecera { display: flex; align-items: center; justify-content: space-between; }
  .precio-nombre { font-size: 1.05rem; font-weight: 700; color: var(--texto); letter-spacing: -0.02em; }
  .precio-valor { display: flex; flex-direction: column; gap: 0.15rem; }

  .precio-monto {
    font-size: clamp(1.4rem, 2.5vw, 1.7rem);
    font-weight: 700; color: var(--texto); letter-spacing: -0.03em;
  }

  .precio-periodo { font-size: 0.75rem; color: var(--texto-terciario); }

  .precio-link {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.8rem; font-weight: 600;
    color: var(--texto-terciario); transition: color var(--transicion);
    margin-top: auto;
  }

  @media (max-width: 1024px) { .grilla-precios { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grilla-precios { grid-template-columns: 1fr; } }
</style>
