---
// ============================================================
// SeccionTestimonios.astro — Grilla de testimonios de clientes
// EDITAR: array TESTIMONIOS abajo
// ============================================================

interface Testimonio {
  texto:   string;
  nombre:  string;
  empresa: string;
  iniciales: string;
}

const TESTIMONIOS: Testimonio[] = [
  {
    texto:    '"Desde que migramos a Salix CRM la gestión del consorcio es otra cosa. Todo más ordenado, los presupuestos se hacen en minutos."',
    nombre:   'Marcela Rodríguez',        // ← EDITAR
    empresa:  'Administradora de consorcios', // ← EDITAR
    iniciales: 'MR',
  },
  {
    texto:    '"Le pedimos la web a Salix y nos sorprendió la calidad. Rápida, moderna y en tiempo récord. Se nota que entienden el negocio."',
    nombre:   'Juan Pablo Ferreira',      // ← EDITAR
    empresa:  'Ferreira Inmobiliaria',    // ← EDITAR
    iniciales: 'JP',
  },
  {
    texto:    '"El soporte es excelente. No es un ticket y esperar días — te responden rápido y resuelven. Eso para nosotros vale mucho."',
    nombre:   'Valentina López',          // ← EDITAR
    empresa:  'LogiCenter SA',            // ← EDITAR
    iniciales: 'VL',
  },
];

const TEXTO = {
  etiqueta:  'Clientes',
  tituloN:   'Lo que dicen',
  tituloG:   'quienes ya usan Salix.',
  subtitulo: 'Empresas argentinas de distintos rubros ya confían en Salix para gestionar su operación diaria.',
};
---

<div class="fondo-puntos">
  <div class="panel-interior">
    <section class="seccion" id="testimonios">

      <span class="etiqueta">{TEXTO.etiqueta}</span>
      <h2 class="titulo-dos-tonos">
        <span class="negro">{TEXTO.tituloN}</span><br>
        <span class="gris">{TEXTO.tituloG}</span>
      </h2>
      <p class="typewriter" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>

      <div class="grilla-testimonios" role="list">
        {TESTIMONIOS.map((t) => (
          <article class="tarjeta-testimonio" role="listitem">
            <p class="texto-testimonio">{t.texto}</p>
            <div class="autor-testimonio">
              <div class="avatar-testimonio" aria-hidden="true">{t.iniciales}</div>
              <div>
                <p class="nombre-autor">{t.nombre}</p>
                <p class="empresa-autor">{t.empresa}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

    </section>
  </div>
</div>

<style>
  .grilla-testimonios { margin-top: 52px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

  .tarjeta-testimonio {
    border: 1px solid var(--borde); border-radius: 16px; padding: 26px; background: var(--fondo);
    display: flex; flex-direction: column; gap: 18px;
    transition: transform .35s, box-shadow .35s, background .5s, border-color .5s;
  }
  .tarjeta-testimonio:hover { transform: translateY(-3px); box-shadow: 0 14px 44px rgba(0,0,0,.08); }

  .texto-testimonio  { font-size: 14px; color: var(--gris-sub); line-height: 1.75; flex: 1; transition: color .5s; }
  .autor-testimonio  { display: flex; align-items: center; gap: 11px; }
  .avatar-testimonio {
    width: 34px; height: 34px; border-radius: 50%; background: var(--card);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: var(--gris-sub); flex-shrink: 0;
    transition: background .5s, color .5s;
  }
  .nombre-autor  { font-size: 13.5px; font-weight: 700; color: var(--texto); transition: color .5s; }
  .empresa-autor { font-size: 12.5px; color: var(--gris-sub); transition: color .5s; }

  @media (max-width: 1024px) { .grilla-testimonios { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .grilla-testimonios { grid-template-columns: 1fr; } }
</style>
