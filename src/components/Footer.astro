---
// ============================================================
// Footer.astro — Pie de página de Salix
// EDITAR: DATOS_CONTACTO y los links de las columnas
// ============================================================

// ---- Datos de contacto — EDITAR ----
const DATOS_CONTACTO = {
  email:     'hola@salixweb.com',                         // ← EDITAR
  whatsapp:  'https://wa.me/5491100000000',               // ← EDITAR
  linkedin:  'https://linkedin.com/company/salixweb',     // ← EDITAR
  instagram: 'https://instagram.com/salixweb',            // ← EDITAR
};

const AÑO = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-contenido">

    <!-- Columna de marca -->
    <div class="footer-marca">
      <a href="/" class="footer-logo" aria-label="Salix inicio">
        <!-- REEMPLAZAR con logo final -->
        <svg class="footer-logo-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 0c-1.5673 0-2.9376.8395-3.6855 2.0938l7.369.0019C14.9357.8402 13.5676 0 12 0zm0 2.7676c-2.3692 0-4.291 1.9188-4.291 4.287h8.5781c0-2.3682-1.9191-4.287-4.2871-4.287zm-4.9531.209c-2.2507 0-4.0762 1.8241-4.0762 4.0742h4.0762V2.9766zm9.9043.002v4.0722l4.0722.002c0-2.2501-1.8234-4.0743-4.0722-4.0743zM7.0469 7.709c-2.3698 0-4.289 1.9224-4.289 4.291 0 2.368 1.9189 4.2871 4.289 4.2871V7.709zm9.9043 0v8.5781c2.3682 0 4.291-1.9191 4.291-4.2871 0-2.3686-1.9228-4.291-4.291-4.291zm-4.9551.002C9.6278 7.711 7.709 9.6316 7.709 12c0 2.3686 1.9188 4.2871 4.287 4.2871 2.3684 0 4.2892-1.9185 4.2892-4.2871 0-2.3683-1.9208-4.289-4.2891-4.289zm-9.9004.6035C.8399 9.062 0 10.4327 0 12c0 1.5666.8398 2.9364 2.0938 3.6855l.0019-7.371zm19.8086 0 .002 7.371C23.1595 14.9364 24 13.5666 24 12c0-1.5673-.8402-2.9379-2.0957-3.6855zM7.0469 16.9492l-4.0742.002c0 2.2491 1.8222 4.0703 4.0742 4.0703v-4.0723zm9.9043 0v4.0703c2.2485 0 4.0722-1.8189 4.0722-4.0683l-4.0722-.002zm-9.2422.002c0 2.3692 1.9218 4.289 4.291 4.289 2.368 0 4.2871-1.9198 4.2871-4.289H7.709zm.5488 4.9531C9.0061 23.1592 10.3755 24 11.9434 24c1.5672 0 2.9366-.8408 3.6855-2.0957H8.258z"/>
        </svg>
        <span class="footer-nombre-logo">Salix</span>
      </a>
      <p class="footer-descripcion">Suite de software para empresas argentinas que quieren crecer de forma ordenada.</p>
    </div>

    <!-- Columnas de links -->
    <nav class="footer-columnas" aria-label="Links del footer">
      <div class="footer-columna">
        <h4>Productos</h4>
        <ul role="list">
          <li><a href="#productos">Salix CRM</a></li>
          <li><a href="#productos">Sites by Salix</a></li>
          <li><a href="#productos">Go by Salix</a></li>
          <li><a href="#productos">Court by Salix</a></li>
          <li><a href="#productos">Turno by Salix</a></li>
        </ul>
      </div>
      <div class="footer-columna">
        <h4>Empresa</h4>
        <ul role="list">
          <li><a href="#porque">Nosotros</a></li>
          <li><a href="#testimonios">Clientes</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>
      <div class="footer-columna">
        <h4>Legal</h4>
        <ul role="list">
          <li><a href="/privacidad">Privacidad</a></li>
          <li><a href="/terminos">Términos</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <!-- Pie del footer -->
  <div class="footer-pie">
    <p>© {AÑO} Salix · salixweb.com</p>
    <p class="footer-hecho">Hecho con ♥ en Argentina</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--borde); background: var(--fondo);
    padding: clamp(40px, 6vw, 72px) clamp(20px, 5vw, 56px);
    position: relative; z-index: 2; transition: background .5s, border-color .5s;
  }
  .footer-contenido { max-width: 1080px; margin: 0 auto; display: flex; justify-content: space-between; gap: 48px; margin-bottom: 48px; flex-wrap: wrap; }
  .footer-marca { max-width: 240px; }
  .footer-logo  { display: flex; align-items: center; gap: 9px; text-decoration: none; color: var(--texto); margin-bottom: 13px; transition: color .5s; }
  .footer-logo-svg  { height: 22px; width: auto; }
  [data-tema="claro"]  .footer-logo-svg path { fill: #0a0a0a; }
  [data-tema="oscuro"] .footer-logo-svg path { fill: #efefef; }
  .footer-nombre-logo { font-size: 15px; font-weight: 700; }
  .footer-descripcion { font-size: 13.5px; color: var(--gris-sub); line-height: 1.65; transition: color .5s; }
  .footer-columnas { display: flex; gap: 52px; flex-wrap: wrap; }
  .footer-columna h4 { font-size: 11.5px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--gris-titulo); margin-bottom: 14px; transition: color .5s; }
  .footer-columna ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .footer-columna a  { font-size: 13.5px; color: var(--gris-sub); text-decoration: none; transition: color .2s; }
  .footer-columna a:hover { color: var(--texto); }
  .footer-pie { max-width: 1080px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding-top: 24px; border-top: 1px solid var(--borde); flex-wrap: wrap; gap: 12px; transition: border-color .5s; }
  .footer-pie p     { font-size: 13px; color: var(--gris-titulo); transition: color .5s; }

  @media (max-width: 1024px) { .footer-contenido { flex-direction: column; } }
  @media (max-width: 600px)  { .footer-pie { flex-direction: column; text-align: center; } }
</style>
