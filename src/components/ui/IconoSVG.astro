const contenidoIcono = ICONOS[nombre] ?? ICONOS['flecha'];
---

<svg
  class={`icono-svg ${clase}`}
  width={tamaño}
  height={tamaño}
  viewBox="0 0 24 24"
  stroke-width={grosor}
  aria-hidden="true"
  set:html={contenidoIcono}
/>
