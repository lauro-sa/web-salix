---
// ============================================================
// IconoSVG.astro — Ícono SVG con animación de dibujo
//
// Los íconos se "dibujan" solos al entrar en el viewport.
// Usa la técnica stroke-dashoffset: el trazo empieza invisible
// y se anima hasta mostrarse completo.
//
// Íconos disponibles (agregar más al objeto ICONOS):
//   edificio, ventana, ubicacion, diamante, calendario,
//   rayo, link, escudo, celular, estrella
//
// Props:
//   nombre    — clave del ícono (string)
//   tamaño    — ancho y alto en px (default: 20)
//   grosor    — stroke-width (default: 1.6)
//   clase     — clases CSS adicionales
// ============================================================

interface Props {
  nombre:  string;
  tamaño?: number;
  grosor?: number;
  clase?:  string;
}

const { nombre, tamaño = 20, grosor = 1.6, clase = '' } = Astro.props;

// ---- Diccionario de íconos SVG ----
// Cada entrada es el contenido del <svg> (los paths/circles internos)
// Podés agregar más íconos copiando el SVG de lucide.dev
const ICONOS: Record<string, string> = {

  edificio: `
    <path d="M3 21h18"/>
    <path d="M5 21V7l7-4 7 4v14"/>
    <path d="M9 21v-6h6v6"/>
    <path d="M9 10h.01M15 10h.01"/>
  `,

  ventana: `
    <rect x="3" y="3" width="18" height="18" rx="2"/>
    <path d="M3 9h18M9 21V9"/>
  `,

  ubicacion: `
    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
    <circle cx="12" cy="9" r="2.5"/>
  `,

  diamante: `
    <path d="M12 2L2 12l10 10 10-10L12 2z"/>
    <path d="M12 2v20M2 12h20"/>
  `,

  calendario: `
    <rect x="3" y="4" width="18" height="18" rx="2"/>
    <path d="M16 2v4M8 2v4M3 10h18"/>
    <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
  `,

  rayo: `
    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
  `,

  link: `
    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
  `,

  escudo: `
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    <path d="M9 12l2 2 4-4"/>
  `,

  celular: `
    <rect x="5" y="2" width="14" height="20" rx="2"/>
    <path d="M12 18h.01"/>
  `,

  estrella: `
    <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/>
  `,

  codigo: `
    <polyline points="16 18 22 12 16 6"/>
    <polyline points="8 6 2 12 8 18"/>
  `,

  cubo: `
    <path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3Z"/>
    <path d="M12 21v-9M4 7.5l8 4.5 8-4.5"/>
  `,

  flecha: `
    <path d="M5 12h14M12 5l7 7-7 7"/>
  `,

  correo: `
    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
    <polyline points="22,6 12,13 2,6"/>
  `,

  // Agregar más íconos acá copiando paths de lucide.dev
};

// Obtener el contenido del ícono solicitado
const contenidoIcono = ICONOS[nombre] ?? ICONOS['flecha'];
---

<!-- Ícono SVG — la clase .icono-svg activa la animación via CSS global -->
<svg
  class={`icono-svg ${clase}`}
  width={tamaño}
  height={tamaño}
  viewBox="0 0 24 24"
  stroke-width={grosor}
  aria-hidden="true"
  set:html={contenidoIcono}
/>
