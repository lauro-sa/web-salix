---
// ============================================================
// SeccionProductos.astro — Grilla de productos con cards
// Cada producto tiene su pagina individual
// ============================================================
import IconoSVG from './ui/IconoSVG.astro';

interface Producto {
  nombre:      string;
  descripcion: string;
  icono:       string;
  disponible:  boolean;
  url:         string;
  color:       string;
}

// Lista de productos — EDITAR
const PRODUCTOS: Producto[] = [
  {
    nombre:      'Flux by Salix',
    descripcion: 'Gestion integral multiempresa. Marketing, correos, WhatsApp, contactos, presupuestos, informes y facturas.',
    icono:       'flujo',
    disponible:  true,
    url:         '/flux',
    color:       'var(--salix)',
  },
  {
    nombre:      'Sites by Salix',
    descripcion: 'Sitios web a medida con tecnologia Salix. Rapidos, con SEO completo y diseño profesional.',
    icono:       'sitio',
    disponible:  true,
    url:         '/sites',
    color:       'var(--salix)',
  },
  {
    nombre:      'Go by Salix',
    descripcion: 'Delivery de comidas. El cliente elige, pide por WhatsApp, paga con MercadoPago y recibe en su puerta.',
    icono:       'delivery',
    disponible:  false,
    url:         '/go',
    color:       'var(--salix)',
  },
  {
    nombre:      'Play by Salix',
    descripcion: 'Gestion de canchas de padel. Turnos fijos, pagos mensuales con links de MercadoPago y control visual.',
    icono:       'cancha',
    disponible:  false,
    url:         '/play',
    color:       'var(--salix)',
  },
  {
    nombre:      'Book by Salix',
    descripcion: 'Gestor de citas para equipos. Psicologia, estetica, consultorios. Turnos por WhatsApp e interfaz simple.',
    icono:       'agenda',
    disponible:  false,
    url:         '/book',
    color:       'var(--salix)',
  },
  {
    nombre:      'Integraciones',
    descripcion: 'Servicio de consultoria e implementacion. Te ayudamos a configurar, integrar y personalizar. Sesiones de 1 hora.',
    icono:       'link',
    disponible:  true,
    url:         '/integraciones',
    color:       'var(--salix)',
  },
];

const TEXTO = {
  etiqueta:  'Productos y servicios',
  titulo:    'Una suite completa.',
  subtitulo: 'Cada producto es una PWA independiente, pensada para resolver un problema especifico. Todas conectadas, todas con WhatsApp y MercadoPago.',
};
---

<section class="seccion" id="productos">

  <div class="encabezado-seccion aparecer">
    <span class="etiqueta">
      <span class="punto-estado" style="background:var(--salix)"></span>
      {TEXTO.etiqueta}
    </span>
    <h2 class="titulo-seccion">{TEXTO.titulo}</h2>
    <p class="typewriter subtitulo" data-texto={TEXTO.subtitulo} aria-label={TEXTO.subtitulo}></p>
  </div>

  <!-- Grilla de productos -->
  <div class="grilla-productos">
    {PRODUCTOS.map((producto, indice) => (
      <a href={producto.url} class={`card-producto aparecer delay-${indice + 1}`}>
        <div class="card-producto-cabecera">
          <div class="icono-contenedor item-producto">
            <IconoSVG nombre={producto.icono} tamaño={22} grosor={1.5} />
          </div>
          <span class={`etiqueta-estado ${producto.disponible ? 'disponible' : 'proximamente'}`}>
            <span class="punto-estado"></span>
            {producto.disponible ? 'Disponible' : 'Proximamente'}
          </span>
        </div>
        <h3 class="card-producto-nombre">{producto.nombre}</h3>
        <p class="card-producto-desc">{producto.descripcion}</p>
        <span class="card-producto-link">
          Conocer mas
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
    ))}
  </div>

</section>

<style>
  .encabezado-seccion {
    margin-bottom: 3rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }

  .grilla-productos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* Card de cada producto */
  .card-producto {
    background: var(--card);
    border: 1px solid var(--borde);
    border-radius: var(--radio-card);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex; flex-direction: column; gap: 1rem;
    transition: all var(--transicion);
    text-decoration: none; color: inherit;
    position: relative; overflow: hidden;
  }

  .card-producto::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px; background: var(--salix);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-producto:hover {
    border-color: var(--salix-borde);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .card-producto:hover::before { transform: scaleX(1); }
  .card-producto:hover .icono-contenedor { transform: scale(1.1) rotate(-5deg); }
  .card-producto:hover .card-producto-link { color: var(--salix); }

  .card-producto-cabecera {
    display: flex; align-items: center; justify-content: space-between;
  }

  .card-producto-nombre {
    font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em;
    color: var(--texto);
  }

  .card-producto-desc {
    font-size: 0.875rem; color: var(--texto-secundario);
    line-height: 1.7; flex: 1;
  }

  .card-producto-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.85rem; font-weight: 600;
    color: var(--texto-terciario);
    transition: color var(--transicion);
    margin-top: auto;
  }

  /* Primera fila: 3 columnas. Segunda fila: 2 centradas */
  .card-producto:nth-child(4),
  .card-producto:nth-child(5) {
    max-width: none;
  }

  @media (max-width: 1024px) {
    .grilla-productos { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grilla-productos { grid-template-columns: 1fr; }
  }
</style>
