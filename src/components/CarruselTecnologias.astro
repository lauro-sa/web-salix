---
// ============================================================
// CarruselTecnologias.astro — Franja con iconos del stack tech
// Las burbujas flotan y se mueven infinitamente.
// ============================================================

// Lista de tecnologias — EDITAR para agregar/quitar
const TECNOLOGIAS = [
  { nombre: 'React',      svg: `<circle cx="12" cy="12" r="2"/><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>` },
  { nombre: 'Next.js',    svg: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Zm-2 13.5v-7l6 7H10Z"/>` },
  { nombre: 'TypeScript', svg: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 11h10M11 11v7"/>` },
  { nombre: 'Astro',      svg: `<path d="M12 3 9 17l3-2 3 2-3-14Z"/><path d="M9 17c0 2 1.3 3 3 3s3-1 3-3"/>` },
  { nombre: 'Node.js',    svg: `<path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3Z"/><path d="M12 21v-9M4 7.5l8 4.5 8-4.5"/>` },
  { nombre: 'Firebase',   svg: `<path d="M6 20 9.5 5l4 6.5-2.5 3L17 20H6Z"/><path d="M9.5 5l7.5 15"/>` },
  { nombre: 'Claude AI',  svg: `<path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/>` },
  { nombre: 'Meta API',   svg: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>` },
  { nombre: 'Vercel',     svg: `<path d="M12 4 22 20H2L12 4Z"/>` },
  { nombre: 'MercadoPago',svg: `<rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/><path d="M6 16h4"/>` },
  { nombre: 'WhatsApp',   svg: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>` },
  { nombre: 'Twilio',     svg: `<circle cx="12" cy="12" r="9"/><circle cx="9" cy="9" r="1.5" fill="currentColor" stroke="none"/><circle cx="15" cy="15" r="1.5" fill="currentColor" stroke="none"/>` },
];
---

<div class="carrusel-tech aparecer" aria-label="Stack tecnologico" aria-hidden="true">
  <div class="carrusel-track" id="carrusel-track">
    {TECNOLOGIAS.map((tech) => (
      <div class="burbuja-tech" title={tech.nombre}>
        <svg
          width="26" height="26"
          viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.4"
          stroke-linecap="round" stroke-linejoin="round"
          set:html={tech.svg}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .carrusel-tech {
    position: relative; z-index: 2; overflow: hidden;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-top: 1px solid var(--borde);
    border-bottom: 1px solid var(--borde);
    background: var(--fondo);
    transition: background var(--transicion), border-color var(--transicion);
  }

  /* Fade en los bordes */
  .carrusel-tech::before,
  .carrusel-tech::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 100px; z-index: 1; pointer-events: none;
  }
  .carrusel-tech::before { left: 0;  background: linear-gradient(to right, var(--fondo), transparent); }
  .carrusel-tech::after  { right: 0; background: linear-gradient(to left,  var(--fondo), transparent); }

  .carrusel-track {
    display: flex; align-items: center; gap: 18px;
    width: max-content;
    animation: desplazar 30s linear infinite;
  }

  .carrusel-tech:hover .carrusel-track { animation-play-state: paused; }

  @keyframes desplazar {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .burbuja-tech {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--card); border: 1px solid var(--borde);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--texto);
    transition: all var(--transicion);
  }

  .burbuja-tech.flotando {
    animation-name: flotar;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
  }

  .burbuja-tech:hover {
    background: var(--fondo); border-color: var(--salix);
    box-shadow: 0 4px 16px rgba(22,163,74,0.12);
    transform: scale(1.12);
    animation-play-state: paused;
  }

  @keyframes flotar {
    from { transform: translateY(0); }
    to   { transform: translateY(-8px); }
  }
</style>

<script>
  // Duplicar burbujas para scroll infinito y activar flotacion
  const track = document.getElementById('carrusel-track');
  if (track) {
    const burbujas = Array.from(track.querySelectorAll('.burbuja-tech'));
    burbujas.forEach((b) => track.appendChild(b.cloneNode(true)));

    Array.from(track.querySelectorAll('.burbuja-tech')).forEach((burbuja, indice) => {
      const duracion = 2.5 + (indice % 7) * 0.27;
      const delay    = -((indice * 0.3) % duracion);
      burbuja.style.animationDuration = duracion + 's';
      burbuja.style.animationDelay    = delay + 's';
      burbuja.classList.add('flotando');
    });
  }
</script>
