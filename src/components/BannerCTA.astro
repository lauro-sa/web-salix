---
// ============================================================
// BannerCTA.astro — Banner de llamada a la acción
// Aparece entre secciones para invitar a contactar.
// EDITAR: CONTENIDO abajo
// ============================================================

const CONTENIDO = {
  etiqueta:    'Sin costo de entrada',   // ← EDITAR
  tituloN:     'Empezá hoy.',            // ← EDITAR
  tituloG:     'Sin compromisos.',       // ← EDITAR
  textoBoton:  'Hablar con nosotros',    // ← EDITAR
  linkBoton:   '#contacto',             // ← EDITAR
};
---

<div class="cta-fondo fondo-puntos">
  <div class="cta-contenido">
    <span class="etiqueta">{CONTENIDO.etiqueta}</span>
    <h2 class="titulo-dos-tonos" style="text-align:center">
      <span class="negro">{CONTENIDO.tituloN}</span><br>
      <span class="gris">{CONTENIDO.tituloG}</span>
    </h2>
    <a href={CONTENIDO.linkBoton} class="boton-oscuro">
      {CONTENIDO.textoBoton}
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .cta-fondo    { position: relative; z-index: 2; padding: clamp(80px, 10vw, 140px) 24px; }
  .cta-contenido { max-width: 600px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 24px; }
</style>
