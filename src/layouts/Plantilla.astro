---
// ============================================================
// Plantilla.astro — Layout base del sitio
// Todos los componentes de pagina usan este layout.
// ============================================================

interface Props {
  titulo:      string;
  descripcion: string;
  imagen?:     string;
}

const {
  titulo,
  descripcion,
  imagen = '/og-image.jpg',
} = Astro.props;

const urlCanonica = Astro.url.href;
---

<!DOCTYPE html>
<html lang="es" data-tema="claro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#fafafa" />

  <!-- SEO Principal -->
  <title>{titulo}</title>
  <meta name="description"  content={descripcion} />
  <meta name="keywords"     content="CRM Argentina, software gestion, delivery, turnos online, canchas padel, PWA" />
  <meta name="author"       content="Salix" />
  <meta name="robots"       content="index, follow" />
  <link rel="canonical"     href={urlCanonica} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={urlCanonica} />
  <meta property="og:title"       content={titulo} />
  <meta property="og:description" content={descripcion} />
  <meta property="og:image"       content={imagen} />
  <meta property="og:locale"      content="es_AR" />
  <meta property="og:site_name"   content="Salix" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={titulo} />
  <meta name="twitter:description" content={descripcion} />
  <meta name="twitter:image"       content={imagen} />

  <!-- Schema.org -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context":    "https://schema.org",
      "@type":       "Organization",
      "name":        "Salix",
      "url":         "https://salixweb.com",
      "description": "Suite de productos de software para empresas argentinas",
      "address": { "@type": "PostalAddress", "addressCountry": "AR" }
    })}
  </script>

  <!-- Tipografia -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- Barra de progreso de scroll -->
  <div id="barra-progreso" style="position:fixed;top:0;left:0;height:2px;width:0;background:var(--salix);z-index:300;border-radius:0 1px 1px 0;transition:width 0.1s linear"></div>

  <!-- Contenido de la pagina -->
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<script>
  import {
    iniciarToggleTema,
    iniciarMenuMobile,
    iniciarBarraProgreso,
    iniciarNavScroll,
    iniciarSmoothScroll,
    iniciarAnimacionIconos,
    iniciarTypewriter,
    iniciarApariciones
  } from '../scripts/utilidades.js';
  import { iniciarParticulas } from '../scripts/particulas.js';

  // Inicializar todo cuando el DOM este listo
  document.addEventListener('DOMContentLoaded', () => {
    iniciarToggleTema('boton-tema');
    iniciarMenuMobile('boton-hamburguesa', 'menu-mobile');
    iniciarBarraProgreso('barra-progreso');
    iniciarNavScroll('nav-principal');
    iniciarSmoothScroll();
    iniciarAnimacionIconos('.item-producto, .item-feature, .item-precio');
    iniciarTypewriter();
    iniciarApariciones();

    // Inicializar grids magneticos en cada seccion que los tenga
    document.querySelectorAll('.grid-magnetico-canvas').forEach((c) => {
      iniciarParticulas(c.id);
    });
  });

  // Animacion de entrada del hero
  window.addEventListener('load', () => {
    const estiloAnim = document.createElement('style');
    estiloAnim.textContent = `
      @keyframes subirLinea {
        from { opacity: 0; transform: translateY(100%); }
        to   { opacity: 1; transform: none; }
      }
      .linea-titulo { opacity: 0; }
    `;
    document.head.appendChild(estiloAnim);

    const badge = document.querySelector('.hero-badge');
    if (badge) {
      badge.style.transition = 'opacity 0.6s ease';
      badge.style.opacity = '1';
    }

    document.querySelectorAll('.linea-titulo').forEach((el, i) => {
      el.style.animation = `subirLinea 0.9s ${0.15 + i * 0.12}s cubic-bezier(0.16,1,0.3,1) forwards`;
    });

    setTimeout(() => {
      const sub  = document.querySelector('.hero-subtitulo');
      const btns = document.querySelector('.hero-botones');
      if (sub)  { sub.style.transition  = 'opacity 0.8s ease'; sub.style.opacity  = '1'; }
      if (btns) { btns.style.transition = 'opacity 0.8s ease 0.1s'; btns.style.opacity = '1'; }
    }, 400);
  });
</script>
