---
// ============================================================
// Plantilla.astro — Layout base del sitio
// Todos los componentes de página usan este layout.
// Modificar el <head> acá afecta a todas las páginas.
// ============================================================

// Props que recibe este layout
interface Props {
  titulo:      string;   // Título de la página (para <title> y OG)
  descripcion: string;   // Meta descripción
  imagen?:     string;   // Imagen OG (opcional)
}

const {
  titulo,
  descripcion,
  imagen = '/og-image.jpg',
} = Astro.props;

// URL canónica para SEO
const urlCanonica = Astro.url.href;
---

<!DOCTYPE html>
<html lang="es" data-tema="claro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#ffffff" />

  <!-- SEO Principal -->
  <title>{titulo}</title>
  <meta name="description"  content={descripcion} />
  <meta name="keywords"     content="CRM Argentina, software gestión, delivery, turnos online, consorcios" />
  <meta name="author"       content="Salix" />
  <meta name="robots"       content="index, follow" />
  <link rel="canonical"     href={urlCanonica} />

  <!-- Open Graph (para compartir en redes y WhatsApp) -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={urlCanonica} />
  <meta property="og:title"       content={titulo} />
  <meta property="og:description" content={descripcion} />
  <meta property="og:image"       content={imagen} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="es_AR" />
  <meta property="og:site_name"   content="Salix" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={titulo} />
  <meta name="twitter:description" content={descripcion} />
  <meta name="twitter:image"       content={imagen} />

  <!-- Schema.org — Datos estructurados para Google -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context":    "https://schema.org",
      "@type":       "Organization",
      "name":        "Salix",
      "url":         "https://salixweb.com",
      "description": "Suite de productos de software para empresas argentinas",
      "address": {
        "@type":          "PostalAddress",
        "addressCountry": "AR"
      }
    })}
  </script>

  <!-- Google Analytics — REEMPLAZAR G-XXXXXXXXXX con tu ID real -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script> -->

  <!-- Meta Pixel — REEMPLAZAR PIXEL_ID con tu ID real -->
  <!-- <script>
    !function(f,b,e,v,n,t,s){...}
    fbq('init', 'PIXEL_ID');
    fbq('track', 'PageView');
  </script> -->

  <!-- Tipografía — Instrument Sans de Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- Barra de progreso de scroll -->
  <div id="barra-progreso" style="position:fixed;top:0;left:0;height:2px;width:0;background:var(--texto);z-index:300;transition:background .5s"></div>

  <!-- Canvas de partículas — fijo en el fondo de toda la página -->
  <canvas
    id="canvas-particulas"
    style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;display:block"
  ></canvas>

  <!-- Contenido de la página -->
  <slot />
</body>
</html>

<!-- Estilos globales -->
<style is:global>
  @import '../styles/global.css';
</style>

<!-- Script de inicialización — se ejecuta en el cliente -->
<script>
  import { iniciarToggleTema, iniciarMenuMobile, iniciarBarraProgreso, iniciarNavScroll, iniciarSmoothScroll, iniciarAnimacionIconos, iniciarTypewriter } from '../scripts/utilidades.js';
  import { iniciarParticulas } from '../scripts/particulas.js';

  // Inicializar todo cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    iniciarToggleTema('boton-tema');
    iniciarMenuMobile('boton-hamburguesa', 'menu-mobile');
    iniciarBarraProgreso('barra-progreso');
    iniciarNavScroll('nav-principal');
    iniciarSmoothScroll();
    iniciarAnimacionIconos('.fila-producto, .item-feature');
    iniciarTypewriter();
    iniciarParticulas('canvas-particulas');
  });

  // Animación de entrada del hero
  window.addEventListener('load', () => {
    // Agregar keyframe al documento
    const estiloAnim = document.createElement('style');
    estiloAnim.textContent = `
      @keyframes subirLinea {
        from { opacity: 0; transform: translateY(100%); }
        to   { opacity: 1; transform: none; }
      }
      .linea-titulo { opacity: 0; }
    `;
    document.head.appendChild(estiloAnim);

    // Animar el badge
    const badge = document.querySelector('.hero-badge');
    if (badge) {
      badge.style.transition = 'opacity 0.6s ease';
      badge.style.opacity    = '1';
    }

    // Animar líneas del título con stagger
    document.querySelectorAll('.linea-titulo').forEach((el, i) => {
      el.style.animation = `subirLinea 0.85s ${0.2 + i * 0.13}s cubic-bezier(0.16,1,0.3,1) forwards`;
    });

    // Animar subtítulo y botones
    setTimeout(() => {
      const sub  = document.querySelector('.hero-subtitulo');
      const btns = document.querySelector('.hero-botones');
      if (sub)  { sub.style.transition  = 'opacity 0.7s ease'; sub.style.opacity  = '1'; }
      if (btns) { btns.style.transition = 'opacity 0.7s ease'; btns.style.opacity = '1'; }
    }, 500);
  });
</script>
